# --- Supabase（必須：ダッシュボードの Project Settings から取得） ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# サーバー専用（管理者 API・RPC で RLS バイパスが必要な場合のみ。クライアントに載せない）
# SUPABASE_SERVICE_ROLE_KEY=

# 任意
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_DEFAULT_TAX_RATE=0.1

# 開発用：在庫シード（設定画面から実行。本番では未設定推奨）
# ALLOW_DEV_SEED=true

# Sentry ブラウザ（未設定なら送信しない。サーバー側は @sentry/nextjs 導入時に別途）
# NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...

# DATABASE_URL=postgresql://...  # Docker / CLI 用マイグレーション

# E2E（Playwright・CI の GitHub Secrets にも同名で設定）
# PLAYWRIGHT_TEST_BASE_URL=http://127.0.0.1:3000
# E2E_TEST_EMAIL=e2e@example.com
# E2E_TEST_PASSWORD=（メール／パスワードのテストユーザー。Supabase で確認メールオフ推奨）
